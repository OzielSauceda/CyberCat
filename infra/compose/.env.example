# Core bridge (Phase 8/9B)
WAZUH_BRIDGE_ENABLED=false
WAZUH_INDEXER_URL=https://wazuh-indexer:9200
WAZUH_INDEXER_USER=cybercat_reader
WAZUH_INDEXER_PASSWORD=CyberCatR3ader!
WAZUH_INDEXER_VERIFY_TLS=true
WAZUH_CA_BUNDLE_PATH=/etc/ssl/certs/wazuh-ca.pem

# Active Response dispatch (Phase 11)
# Set WAZUH_AR_ENABLED=true when running --profile wazuh and lab-debian is enrolled.
WAZUH_AR_ENABLED=false
WAZUH_MANAGER_URL=https://wazuh-manager:55000
WAZUH_MANAGER_USER=wazuh-wui
# Password from wazuh-manager initial setup (check manager logs or ossec.conf).
WAZUH_MANAGER_PASSWORD=

# Lab VM settings
LAB_REALUSER_PASSWORD=lab123
WAZUH_REGISTRATION_PASSWORD=
