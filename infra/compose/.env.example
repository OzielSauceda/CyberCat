# Demo auto-seed (Phase 17.6)
# Seeds the credential_theft_chain scenario on first boot when events table is empty.
# Set to false in any environment with real event ingest or in production.
CCT_AUTOSEED_DEMO=true

# Core bridge (Phase 8/9B)
WAZUH_BRIDGE_ENABLED=false
WAZUH_INDEXER_URL=https://wazuh-indexer:9200
WAZUH_INDEXER_USER=cybercat_reader
WAZUH_INDEXER_PASSWORD=CyberCatR3ader!
WAZUH_INDEXER_VERIFY_TLS=true
WAZUH_CA_BUNDLE_PATH=/etc/ssl/certs/wazuh-ca.pem

# Active Response dispatch (Phase 11)
# Set WAZUH_AR_ENABLED=true when running --profile wazuh and lab-debian is enrolled.
WAZUH_AR_ENABLED=false
WAZUH_MANAGER_URL=https://wazuh-manager:55000
WAZUH_MANAGER_USER=wazuh-wui
# Password from wazuh-manager initial setup (check manager logs or ossec.conf).
WAZUH_MANAGER_PASSWORD=

# Lab VM settings
LAB_REALUSER_PASSWORD=lab123
WAZUH_REGISTRATION_PASSWORD=

# Custom telemetry agent (Phase 16 — see docs/decisions/ADR-0011-direct-agent-telemetry.md)
# CCT_AGENT_TOKEN is auto-provisioned by start.sh on first run when the agent
# profile is active. Leave empty here; start.sh will issue and persist a token
# scoped to the cct-agent@local analyst user.
CCT_AGENT_TOKEN=
# Tuning knobs (optional). Defaults are good for the lab.
CCT_BATCH_SIZE=50
CCT_FLUSH_INTERVAL_SECONDS=2.0
# Phase 16.9: auditd-driven process.created / process.exited events.
# Set to false to run the agent in sshd-only mode (e.g. when running outside
# lab-debian or when kernel audit is unavailable). Default: enabled.
CCT_AUDIT_ENABLED=true
# Phase 16.10: conntrack-driven network.connection events.
# Set to false to skip the conntrack tail (e.g. when running outside lab-debian
# or when kernel conntrack netlink is inaccessible). Default: enabled.
CCT_CONNTRACK_ENABLED=true
